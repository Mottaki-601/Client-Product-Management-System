@model _1291387.Models.ViewModels.ClientVM
@{
    ViewBag.Title = "Create Client";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <div class="card-header bg-primary bg-gradient text-white p-4 text-center">
            <h2 class="fw-bold mb-0"><i class="fas fa-user-plus me-2"></i>Client Registration Portal</h2>
            <p class="mb-0 opacity-75">Fill in the client details and assign products in one go</p>
        </div>

        @using (Ajax.BeginForm(new AjaxOptions
        {
            HttpMethod = "POST",
            InsertionMode = InsertionMode.Replace,
            UpdateTargetId = "msg",
            OnComplete = "clearAll"
        }))
        {
            @Html.AntiForgeryToken()

            <div class="card-body p-4 p-lg-5">
                <div class="row g-5">

                    <div class="col-lg-6">
                        <div class="d-flex align-items-center mb-4 border-bottom pb-2">
                            <span class="badge bg-primary rounded-circle me-2">1</span>
                            <h4 class="mb-0 text-primary">Client Profile</h4>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">@Html.DisplayNameFor(x => x.clientName)</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white"><i class="fas fa-user text-primary"></i></span>
                                @Html.TextBoxFor(x => x.clientName, new { @class = "form-control", placeholder = "Enter full name" })
                            </div>
                            @Html.ValidationMessageFor(x => x.clientName, "", new { @class = "text-danger small fw-bold" })
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Birth Date</label>
                                @Html.TextBoxFor(x => x.birthDate, new { @class = "form-control shadow-sm", type = "date" })
                                @Html.ValidationMessageFor(x => x.birthDate, "", new { @class = "text-danger small" })
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Current Age</label>
                                @Html.TextBoxFor(x => x.age, new { @class = "form-control shadow-sm", placeholder = "Ex: 25", @readonly = "readonly" })
                                @Html.ValidationMessageFor(x => x.age, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Profile Photo</label>
                            @Html.TextBoxFor(x => x.pictureFile, new { @class = "form-control shadow-sm", type = "file" })
                            @Html.ValidationMessageFor(x => x.pictureFile, "", new { @class = "text-danger small" })
                        </div>

                        <div class="p-3 bg-light rounded-3 border">
                            <div class="form-check form-switch">
                                @Html.CheckBoxFor(x => x.insideDhaka, new { @class = "form-check-input", id = "flexSwitchCheckDefault" })
                                <label class="form-check-label fw-bold" for="flexSwitchCheckDefault">Client resides inside Dhaka?</label>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6 bg-light-subtle rounded-4 p-4 border">
                        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-success rounded-circle me-2">2</span>
                                <h4 class="mb-0 text-success">Product List</h4>
                            </div>
                            <a href="#" id="btnPlus" class="btn btn-outline-success btn-sm rounded-pill px-3">
                                <i class="fa fa-plus me-1"></i> Add Item
                            </a>
                        </div>

                        <div id="productContainer" class="pe-2" style="max-height: 380px; overflow-y: auto;">
                            <div class="product-item shadow-sm bg-white p-3 rounded-3 mb-3 border-start border-success border-4">
                                @Html.Action("AddNewProduct", "Clients")
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="card-footer bg-white p-4 border-top d-flex justify-content-between align-items-center">
                <div id="msg" class="flex-grow-1 me-3"></div>
                <div class="btn-group">
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4 me-2 rounded-pill">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow">
                        <i class="fas fa-cloud-upload-alt me-2"></i>Save All Records
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<style>
    body {
        background-color: #f0f2f5;
    }

    .bg-light-subtle {
        background-color: #f8f9fa;
    }

    #productContainer::-webkit-scrollbar {
        width: 5px;
    }

    #productContainer::-webkit-scrollbar-thumb {
        background: #198754;
        border-radius: 10px;
    }

    .card-header {
        border-bottom: none;
    }
</style>

@section scripts{
    <script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>

    <script>
        $(document).ready(function () {
            $("#form0").attr("enctype", "multipart/form-data");
        });

        function clearAll() {
            if ($("#msg").text().includes("Success") || $("#msg").hasClass("alert-success")) {
                $("#form0").trigger("reset");
            }
        }
    </script>

        <script>
            $(document).ready(function () {
                $("#form0").attr("enctype", "multipart/form-data");

                $("#birthDate").on("change", function () {
                    var dob = new Date($(this).val());
                    if (dob != "Invalid Date") {
                        var today = new Date();
                        var age = today.getFullYear() - dob.getFullYear();
                        var m = today.getMonth() - dob.getMonth();

                        if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) {
                            age--;
                            alert("Birth date cannot be in the future! Please select a valid date.");
                        }

                        $("#age").val(age >= 0 ? age : 0);
                    }
                });
            });

            function clearAll() {
                if ($("#msg").text().includes("Success") || $("#msg").hasClass("alert-success")) {
                    $("#form0").trigger("reset");
                }
            }
        </script>
    }


