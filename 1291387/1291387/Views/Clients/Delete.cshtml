@model _1291387.Models.ViewModels.ClientVM

@{
    ViewBag.Title = "Confirm Delete";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <div class="card-header bg-danger text-white p-4">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-exclamation-triangle fa-3x me-3"></i>
                        <div>
                            <h2 class="mb-0 fw-bold">Permanent Deletion</h2>
                            <p class="mb-0 opacity-75">Are you sure you want to remove this client and all associated product records?</p>
                        </div>
                    </div>
                </div>

                @using (Html.BeginForm("Delete", "Clients", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(x => x.clientId)
                    @Html.HiddenFor(x => x.picture)

                    <div class="card-body p-4 bg-light-subtle">
                        <div class="row">

                            <div class="col-md-5 border-end">
                                <div class="text-center mb-4">
                                    <img src="@Model.picture" class="rounded-circle img-thumbnail shadow-sm mb-3" width="120" height="120" style="object-fit: cover;" />
                                    <h4 class="fw-bold text-dark">@Model.clientName</h4>
                                    <span class="badge @(Model.insideDhaka ? "bg-success" : "bg-secondary") rounded-pill">
                                        <i class="fas fa-map-marker-alt me-1"></i> @(Model.insideDhaka ? "Inside Dhaka" : "Outside Dhaka")
                                    </span>
                                </div>

                                <div class="p-3 bg-white rounded-3 shadow-sm">
                                    <div class="mb-2">
                                        <label class="text-muted small fw-bold text-uppercase">Birth Date</label>
                                        <p class="mb-0">@Model.birthDate.ToString("dd MMMM, yyyy")</p>
                                    </div>
                                    <div class="mb-0">
                                        <label class="text-muted small fw-bold text-uppercase">Client Age</label>
                                        <p class="mb-0">@Model.age Years</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-7 ps-md-4">
                                <h5 class="text-danger fw-bold mb-3 border-bottom pb-2">
                                    <i class="fas fa-boxes me-2"></i>Linked Products to be Removed
                                </h5>

                                <div id="productContainer" class="rounded-3 overflow-hidden border shadow-sm" style="max-height: 300px; overflow-y: auto;">
                                    @if (Model.ProductList != null && Model.ProductList.Any())
                                    {
                                        foreach (var item in Model.ProductList)
                                        {
                                            <div class="bg-white p-2 border-bottom d-flex align-items-center">
                                                <i class="fas fa-arrow-right text-danger me-2 small"></i>
                                                @Html.Action("AddNewProduct", "Clients", new { id = item })
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="p-4 text-center text-muted italic">
                                            No products associated with this client.
                                        </div>
                                    }
                                </div>
                                <p class="text-muted small mt-2 italic"><i class="fas fa-info-circle me-1"></i> Removing the client will also delete the above entries from the database.</p>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-white p-3 d-flex justify-content-between align-items-center">
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4 rounded-pill fw-bold">
                            <i class="fas fa-times me-1"></i> Cancel & Go Back
                        </a>
                        <button type="submit" class="btn btn-danger btn-lg px-5 shadow rounded-pill fw-bold">
                            <i class="fas fa-trash-alt me-2"></i> Confirm Delete
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    input, select {
        pointer-events: none;
        background-color: #f8f9fa !important;
        border-color: #eee !important;
    }

    .btn {
        pointer-events: auto !important;
    }
</style>