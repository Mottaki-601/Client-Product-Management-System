@model _1291387.Models.product
@{
    var uniqueId = Guid.NewGuid().ToString().Substring(0, 8);
}

<div class="product-item position-relative mb-3 animate__animated animate__fadeIn" id="product-@uniqueId">
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden border-start border-primary border-4">
        <div class="card-body p-3">
            <div class="row align-items-center g-2">

                <div class="col-10">
                    <div class="d-flex align-items-center">
                        <div class="me-2 text-primary opacity-75">
                            <i class="fas fa-box-open fa-lg"></i>
                        </div>
                        <div class="flex-grow-1">
                            <label class="small text-muted fw-bold mb-1 d-block text-uppercase" style="font-size: 0.65rem; letter-spacing: 1px;">
                                Select Product Category
                            </label>
                            @Html.DropDownListFor(x => x.productId,
                                ViewBag.products as SelectList,
                                "---- Choose Item ----",
                                htmlAttributes: new { @class = "form-select border-0 bg-light-subtle fw-semibold text-dark shadow-none" })
                        </div>
                    </div>
                    @Html.ValidationMessageFor(x => x.productId, "", new { @class = "text-danger small" })
                </div>

                <div class="col-2 text-end">
                    <button type="button" class="btn btn-sm btn-light border-0 rounded-circle shadow-sm btnRemove text-danger p-2"
                            style="width: 35px; height: 35px; transition: all 0.3s;"
                            title="Remove this item">
                        <i class="fa fa-trash-alt"></i>
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>

