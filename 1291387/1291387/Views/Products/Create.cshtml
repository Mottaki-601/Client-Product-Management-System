@model _1291387.Models.product

@{
    ViewBag.Title = "Create Product";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card shadow-lg border-0 rounded-3">

                <div class="card-header bg-success text-white p-3">
                    <h4 class="mb-0 text-center"><i class="fas fa-plus-circle me-2"></i>Create New Product</h4>
                </div>

                <div class="card-body p-4">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()

                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger d-none" })

                        <div class="mb-4">
                            @Html.LabelFor(model => model.productName, "Product Name", new { @class = "form-label fw-bold text-secondary" })

                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fas fa-box text-success"></i>
                                </span>
                                @Html.EditorFor(model => model.productName, new { htmlAttributes = new { @class = "form-control border-start-0", @placeholder = "Enter product name...", @autocomplete = "off" } })
                            </div>
                            @Html.ValidationMessageFor(model => model.productName, "", new { @class = "text-danger small mt-1 fw-bold" })
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                <i class="fas fa-check me-2"></i> Save Product
                            </button>

                            <a href="@Url.Action("Index")" class="btn btn-light border mt-2">
                                <i class="fas fa-arrow-left me-2"></i> Back to List
                            </a>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        $(document).ready(function () {
            if ($(".validation-summary-errors").length > 0) {
                $(".validation-summary-errors").addClass("alert alert-danger");
            }
        });
    </script>
}