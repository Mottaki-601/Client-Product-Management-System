<div class="container mt-4">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden animate__animated animate__shakeX" style="max-width: 500px; margin: 0 auto;">
        <div class="card-body p-4">
            <div class="d-flex align-items-center">
                <div class="flex-shrink-0 bg-danger bg-opacity-10 p-3 rounded-circle me-3">
                    <i class="fas fa-database text-danger fa-2x pulse-icon"></i>
                </div>

                <div class="flex-grow-1">
                    <h5 class="text-danger fw-bold mb-1">Database Sync Failed!</h5>
                    <p class="text-muted small mb-0">
                        We couldn't process your request. Please check your connection or try again later.
                    </p>
                </div>

                <button type="button" class="btn-close ms-2" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <div class="mt-3 d-flex justify-content-end">
                <button onclick="location.reload()" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                    <i class="fas fa-sync-alt me-1"></i> Retry Now
                </button>
            </div>
        </div>

        <div class="progress" style="height: 4px;">
            <div class="progress-bar bg-danger" role="progressbar" style="width: 100%"></div>
        </div>
    </div>
</div>

<style>
    .pulse-icon {
        animation: pulse-red 2s infinite;
    }

    @@keyframes pulse-red {
        0% { transform: scale(0.95); opacity: 0.7; }
        70% { transform: scale(1.1); opacity: 1; }
        100% { transform: scale(0.95); opacity: 0.7; }
    }

    .card:hover {
        box-shadow: 0 10px 30px rgba(220, 53, 69, 0.2) !important;
        transition: all 0.3s ease;
    }
</style>